{
  "ConnectionStrings": { "FinancialDb": "" },
  "Portal": {
    "GatewayBaseUrl": "http://localhost:8080",
    "UsePortalAudit": false,
    "UsePortalNotification": false,
    "UsePortalOutbox": false,
    "UsePortalConfiguration": false
  },
  "FinancialPlatform": { "TenantId": "default", "CorrelationHeader": "X-Correlation-ID" },
  "Database": { "Initialize": false, "RunMigrations": false },
  "Jwt": { "Issuer": "portal-corporativo", "Audience": "portal-corporativo-clients" },
  "Seq": { "ServerUrl": "http://localhost:5341" },
  "financial": {
    "secrets": {
      "provider": "Disabled",
      "keyVaultName": "",
      "useDefaultAzureCredential": false,
      "requireManagedIdentity": false,
      "allowDevelopmentSecrets": false,
      "maskSecretsInLogs": true,
      "failFastOnStartup": false
    },
    "sri": {
      "issuer": {
        "ruc": "9999999999999",
        "legalName": "EMISOR DESARROLLO",
        "tradeName": "EMISOR DESARROLLO",
        "address": "DIRECCION DESARROLLO",
        "accountingRequired": true
      },
      "environment": "Test",
      "integration": { "mode": "Development" },
      "allowProduction": false,
      "logPayloads": false,
      "maskPayloads": true,
      "test": {
        "dryRun": true,
        "allowConnectivityProbe": false,
        "allowDocumentSend": false,
        "manualValidationRequired": true,
        "useSyntheticDocumentOnly": true,
        "syntheticIssuerRuc": "9999999999999",
        "syntheticCustomerIdentification": "9999999999",
        "maxManualAttempts": 1
      },
      "emissionType": "Normal",
      "defaultEstablishmentCode": "001",
      "defaultEmissionPointCode": "001",
      "signature": {
        "provider": "Development",
        "certificateSource": "SecretStore",
        "certificateSecretName": "",
        "certificatePasswordSecretName": "",
        "keyVaultName": "",
        "timestampPolicy": "",
        "requireOcsp": false,
        "localCertificatePath": "",
        "localCertificatePasswordSecretName": "",
        "requireTrustedCertificate": true
      },
      "receptionUrl": "",
      "authorizationUrl": "",
      "timeoutSeconds": 30,
      "maxRetries": 3,
      "retryDelaySeconds": 5,
      "xml": {
        "version": { "invoice": "1.0.0" },
        "includeOptionalFields": false,
        "validation": {
          "mode": "Basic",
          "failOnWarning": true
        }
      },
      "storage": {
        "provider": "Development",
        "portalBaseUrl": "",
        "container": "financial-electronic-documents",
        "timeoutSeconds": 30,
        "sendPayloads": false,
        "maskPayloads": true,
        "allowProductionContentFilePayload": false,
        "retainXml": true,
        "retainPdf": false
      }
    }
  },
  "Serilog": { "MinimumLevel": { "Default": "Information", "Override": { "Microsoft.AspNetCore": "Warning" } } },
  "AllowedHosts": "*"
}
